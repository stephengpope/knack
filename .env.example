# ── Database (Neon Postgres — auto-provisioned by the Vercel Deploy Button) ──
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Better Auth ──
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL of the app (no trailing slash). Local: http://localhost:3000
# On Vercel this is derived from the deployment URL automatically — leave unset.
BETTER_AUTH_URL="http://localhost:3000"

# ── Encryption (per-user provider keys at rest, AES-256-GCM) ──
# 32 bytes, base64: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── Cron / scheduled runs ──
# Bearer token guarding the cron endpoints: openssl rand -hex 32
CRON_SECRET=""

# ── Email (Resend — required) ──
# Get a free API key at https://resend.com (Marketplace integration also works).
RESEND_API_KEY=""
# Verified sender. Until you verify a domain, "Knack <onboarding@resend.dev>"
# only delivers to the Resend account owner's email.
RESEND_FROM="Knack <onboarding@resend.dev>"

# ── AI Gateway (Vercel) ──
# On Vercel this is provided automatically via OIDC; set locally for dev.
AI_GATEWAY_API_KEY=""
