# ── Database (Neon Postgres — auto-provisioned by the Vercel Deploy Button) ──
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Better Auth ──
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL of the app (no trailing slash). Local: http://localhost:3000
# On Vercel this is derived from the deployment URL automatically — leave unset.
BETTER_AUTH_URL="http://localhost:3000"

# ── Encryption (per-user provider keys at rest, AES-256-GCM) ──
# 32 bytes, base64: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── Cron / scheduled runs ──
# Bearer token guarding the cron endpoints: openssl rand -hex 32
CRON_SECRET=""

# ── Email (SMTP) ──
# Optional. Configured in-app under Administration → Email (stored in the DB),
# not via env. When unset, password-reset/invite emails fall back to copyable
# links and the "Forgot password?" link is hidden.

# ── AI Gateway (Vercel) ──
# On Vercel this is provided automatically via OIDC; set locally for dev.
AI_GATEWAY_API_KEY=""
