# ── Database (Neon Postgres — provisioned via Vercel Marketplace) ──
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Better Auth ──
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL of the app (no trailing slash). Local: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# ── Encryption (per-user provider keys at rest, AES-256-GCM) ──
# 32 bytes, base64: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── AI Gateway (Vercel) ──
# On Vercel this is provided automatically via OIDC; set locally for dev.
AI_GATEWAY_API_KEY=""
